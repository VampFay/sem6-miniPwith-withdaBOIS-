# Optional overrides. Never commit credentials or patient data.
ATTNDIST_DATA_DIR=data/pannuke
ATTNDIST_OUTPUT_DIR=outputs_v2
ATTNDIST_CHECKPOINT=outputs_v2/checkpoints/best_iou_calibrated.pt
ATTNDIST_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
ATTNDIST_MAX_UPLOAD_BYTES=26214400
ATTNDIST_MAX_IMAGE_PIXELS=4194304
ATTNDIST_MAX_MULTIPART_OVERHEAD_BYTES=262144
ATTNDIST_ENABLE_DOCS=1

# Controlled deployment only. Keep research mode until every release gate is formally approved.
ATTNDIST_OPERATING_MODE=research
ATTNDIST_RELEASE_ID=development
# ATTNDIST_APPROVED_CHECKPOINT_SHA256=<64 lowercase hex characters>
# ATTNDIST_AUDIT_DIR=/var/lib/attn-dist/audit
# ATTNDIST_API_TOKEN=<inject from a secret manager; never commit>
# ATTNDIST_SBOM_RECEIPT=outputs_v2/release/sbom.cdx.json.receipt.json
